  "tags": [
    {
      "name": "GA4 - Config",
      "type": "Google Tag (gtag)",
      "measurementId": "{{const - ga4_measurement_id}}",
      "serverContainerUrl": "{{const - server_container_url}}",
      "configSettings": {
        "send_page_view": false
      },
      "firingTrigger": "All Pages",
      "consentSettings": {
        "analytics_storage": "required",
        "note": "Config tag requires analytics consent before initializing GA4"
      },
      "note": "GA4 config tag. send_page_view is false because page views are pushed explicitly from app code via data layer. Server container URL routes hits through sGTM on io.iampatterson.com."
    },
    {
      "name": "GA4 - page_view",
      "type": "GA4 Event (gaawe)",
      "eventName": "page_view",
      "parameters": {
        "iap_source": "{{dlv - iap_source}}",
        "timestamp": "{{dlv - timestamp}}",
        "session_id": "{{dlv - session_id}}",
        "page_path": "{{dlv - page_path}}",
        "page_title": "{{dlv - page_title}}",
        "page_referrer": "{{dlv - page_referrer}}",
        "consent_analytics": "{{dlv - consent_analytics}}",
        "consent_marketing": "{{dlv - consent_marketing}}",
        "consent_preferences": "{{dlv - consent_preferences}}"
      },
      "firingTrigger": "ce - page_view",
      "consentSettings": { "analytics_storage": "required" }
    },
    {
