# Metabase Cloud Run environment variables — reference for Task 3.
#
# This file documents every variable that `cloudrun.yaml` sets on the
# Metabase container. NO ACTUAL SECRET VALUES are in this file — any
# `Source:` line that references Secret Manager points to where the real
# value lives. Copy this file if you need a local dev baseline and fill
# in values yourself; never commit a filled copy.
#
# When rebuilding the Metabase deployment from scratch, the source of
# truth is:
#   - cloudrun.yaml          — how each variable is delivered to the
#                              container at deploy time
#   - input_artifacts/metabase-deployment-plan.md (Task 3) — the spec

# MB_DB_TYPE
# Tells Metabase which application database driver to use. Must be set
# to `postgres` explicitly. If unset, Metabase silently falls back to an
# embedded H2 database, which would break all encrypted credentials and
# dashboards on next restart. This is the single most important variable
# in the file.
# Source: constant in cloudrun.yaml
MB_DB_TYPE=postgres

# MB_DB_HOST
# Postgres host. In Cloud Run, this is the Unix socket mounted by the
# Cloud SQL Auth Proxy sidecar (activated by the
# `run.googleapis.com/cloudsql-instances` annotation in cloudrun.yaml).
# Format: /cloudsql/<PROJECT>:<REGION>:<INSTANCE_NAME>
# Source: constant in cloudrun.yaml, value
#         /cloudsql/iampatterson:us-central1:metabase-app-db
MB_DB_HOST=/cloudsql/iampatterson:us-central1:metabase-app-db

# MB_DB_PORT
# Postgres port. Default 5432. Unix-socket connections ignore the port
# but Metabase still wants the value set.
# Source: constant in cloudrun.yaml
MB_DB_PORT=5432

# MB_DB_DBNAME
# Name of the Postgres database on the Cloud SQL instance. Created by
# setup-cloudsql.sh (Task 1).
# Source: constant in cloudrun.yaml
MB_DB_DBNAME=metabase

# MB_DB_USER
# Postgres user. Created by setup-cloudsql.sh (Task 1) with a random
# password stored in Secret Manager.
# Source: constant in cloudrun.yaml
MB_DB_USER=metabase

# MB_DB_PASS
# Postgres password for MB_DB_USER. Generated once by setup-cloudsql.sh
# (openssl rand -base64 24) and stored in Secret Manager. The value is
# delivered to the container by Cloud Run via secretKeyRef — never on
# the command line, never written to this file.
# Retrieve manually (e.g. for psql or UI DB config):
#   gcloud secrets versions access latest --secret=metabase-db-password
# Source: Secret Manager (metabase-db-password:latest)
MB_DB_PASS=

# MB_SITE_URL
# The public URL visitors use to reach Metabase. Must match the hostname
# on the Task 5 load balancer's SSL cert or Metabase generates broken
# links and its CSRF tokens misfire. Update both this value and the
# domain reserved in setup-domain.sh if you move off bi.iampatterson.com.
# Source: constant in cloudrun.yaml
MB_SITE_URL=https://bi.iampatterson.com

# JAVA_TOOL_OPTIONS
# JVM options for the Metabase process. -Xmx1800m caps the heap well
# below the 2Gi container limit, leaving room for Metaspace, native
# allocations, and Cloud Run's container overhead. Raising this above
# the container limit triggers OOM kills.
# Source: constant in cloudrun.yaml
JAVA_TOOL_OPTIONS=-Xmx1800m

# MB_ENCRYPTION_SECRET_KEY
# Encrypts credentials stored in the Postgres app DB — most importantly
# the BigQuery service account JSON that Metabase saves internally when
# you add the data source (Task 7). Generated once via
# `openssl rand -base64 32` and stored in Secret Manager as
# `metabase-encryption-key`.
#
# DO NOT REGENERATE. Rotating this key without a coordinated re-enter of
# every encrypted credential breaks Metabase's ability to decrypt rows
# already in the app DB — the BigQuery connection stops working and
# the only recovery is to re-add the data source in the UI. setup-iam.sh
# refuses to regenerate if the secret already exists; honor that.
#
# Retrieve (only for disaster recovery):
#   gcloud secrets versions access latest --secret=metabase-encryption-key
# Source: Secret Manager (metabase-encryption-key:latest)
MB_ENCRYPTION_SECRET_KEY=

# -----------------------------------------------------------------------------
# Variables Cloud Run provides automatically (NOT in cloudrun.yaml)
# -----------------------------------------------------------------------------

# PORT
# Cloud Run sets PORT=8080 on the container. Metabase's Jetty listens on
# whatever PORT resolves to. Don't override it in cloudrun.yaml — Cloud
# Run will refuse traffic to a container listening on a different port.
# Source: Cloud Run runtime (not set by us)
# PORT=8080
