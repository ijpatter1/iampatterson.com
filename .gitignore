!docs/perf/mobile-matrix-screenshots/2026-04-25/matrix-iphone-13__home__01-at-rest.png
!docs/perf/mobile-matrix-screenshots/2026-04-25/matrix-pixel-5__home__01-at-rest.png
!docs/perf/mobile-matrix-screenshots/2026-04-25/matrix-pixel-5__home__02-overlay-overview.png
!docs/perf/mobile-matrix-screenshots/2026-04-25/matrix-ipad-mini-portrait__ecommerce-product__01-at-rest.png
!docs/perf/mobile-matrix-screenshots/2026-04-25/matrix-ipad-mini-landscape__ecommerce-cart__01-at-rest.png
!docs/perf/mobile-matrix-screenshots/2026-04-25/matrix-ipad-mini-landscape__home__01-at-rest.png

