*.tfstate
*.tfstate.*
.terraform/

# ─────────────────────────────────────────────
# Python (background data generator, Phase 4+)
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
*.egg-info/


# ─────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────
*.bak
*.tmp
*.temp
docs/tag_assistant_*.json
docs/input_artifacts/

# Lighthouse HTML reports — the JSON is the machine-diffable artifact we
# commit; HTML is the human view and adds ~800KB per route per run.
docs/perf/lighthouse-*.report.html

# Mobile-matrix screenshots — a full sweep is 120 PNGs / ~48MB per run.
# We commit only the curated evidence subset referenced in the matrix
# doc (force-add what we want; gitignore the rest). Regenerate the full
# sweep via `bash scripts/capture-mobile-matrix.sh` when needed.
docs/perf/mobile-matrix-screenshots/**/*.png
!docs/perf/mobile-matrix-screenshots/2026-04-25/matrix-iphone-se__home__01-at-rest.png
!docs/perf/mobile-matrix-screenshots/2026-04-25/matrix-iphone-se__home__02-overlay-overview.png
!docs/perf/mobile-matrix-screenshots/2026-04-25/matrix-iphone-se__home__03-consent-storage.png
